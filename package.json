{
  "name": "parkly",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --clear",
    "prep:xcode": "bash scripts/prep-xcode.sh",
    "start:clear": "expo start --clear",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "postinstall": "patch-package",
    "fetch:copenhagen-parking": "node scripts/fetch-copenhagen-osm-parking.mjs",
    "fetch:fb-parking": "node scripts/fetch-frederiksberg-parking-osm.mjs",
    "emulators:start": "firebase emulators:start --only auth,firestore,functions --import=./emulator-data --export-on-exit=./emulator-data",
    "emulators:clear": "rm -rf emulator-data && mkdir -p emulator-data"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "expo": "~50.0.0",
    "expo-asset": "~9.0.2",
    "expo-constants": "~15.4.6",
    "expo-font": "~11.10.3",
    "expo-linking": "~6.2.2",
    "expo-location": "~16.5.5",
    "expo-notifications": "~0.27.8",
    "expo-router": "~3.4.10",
    "expo-status-bar": "~1.11.1",
    "expo-task-manager": "~11.7.3",
    "firebase": "^10.7.1",
    "react": "18.2.0",
    "react-native": "^0.73.6",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-maps": "^1.10.0",
    "react-native-reanimated": "~3.6.1",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^25.0.9",
    "@types/react": "~18.2.45",
    "@types/react-native": "~0.73.0",
    "jest": "^29.2.1",
    "patch-package": "^8.0.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.1.3"
  },
  "private": true
}
